class ListNode:
    def __init__(self, val=0, next=None):
        self.val = val
        self.next = next
class Solution:
    def mergeKLists(self, lists: List[Optional[ListNode]]) -> Optional[ListNode]:
        result = []
        for head in lists:
            current = head
            while current:
                result.append(current.val)
                current = current.next
        result.sort()
        dummy = ListNode(0)
        current = dummy

        for i in result:
            current.next = ListNode(i)
            current = current.next
        return dummy.next
