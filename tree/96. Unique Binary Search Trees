class Solution:
    def numTrees(self, n: int) -> int:
        G = [0] * (n + 1)
        G[0] = 1   
        
        for nodes in range(1, n + 1):
            for root in range(1, nodes + 1):
                left = root - 1       
                right = nodes - root    
                G[nodes] += G[left] * G[right]
        
        return G[n]
